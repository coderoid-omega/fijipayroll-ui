# Dev defaults. Mock-first (CLAUDE.md §6), integrating one epic at a time.
VITE_API_BASE_URL=/api/v1
VITE_ENABLE_MSW=true
# Resources served by the REAL .NET API instead of mocks (per-route toggle). Epic 1 = auth.
VITE_MSW_LIVE_RESOURCES=auth
# Where Vite proxies /api when a resource is live (the .NET API runs on :5056).
VITE_API_PROXY_TARGET=http://localhost:5056
