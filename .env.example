# Copy to .env.local and adjust. All client-exposed vars MUST be prefixed VITE_.

# Base URL for the REST API. Same-origin "/api/v1" works with the Vite dev proxy
# and with MSW (which intercepts fetch/XHR regardless of host).
VITE_API_BASE_URL=/api/v1

# Turn the Mock Service Worker on ("true") to run the whole app without a backend,
# or off ("false") to hit the real .NET API (via the dev proxy below).
VITE_ENABLE_MSW=true

# Where the Vite dev server proxies /api when MSW is OFF (the local .NET API).
VITE_API_PROXY_TARGET=http://localhost:5080
